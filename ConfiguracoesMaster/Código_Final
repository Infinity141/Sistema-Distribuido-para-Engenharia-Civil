import redis
from rq import Queue
import cloudpickle
import numpy as np
import io
import time

# 1. Configuração da Conexão com o Broker Remoto
REDIS_IP = '10.10.10.10'  # Altere para o IP real do seu Broker
SENHA = 'liama'
REDIS_URL = f'redis://:{SENHA}@{REDIS_IP}:6379'

# Conexão direta com o Redis para podermos usar comandos nativos (como LPOP)
r_client = redis.from_url(REDIS_URL)

# Conexão da fila do RQ usando o cloudpickle para serializar o código
fila = Queue('calculos_matriz', connection=r_client, serializer=cloudpickle)

# --- A FUNÇÃO QUE SERÁ ENVIADA PARA OS WORKERS ---
def processar_e_listar(p, particoes, redis_url, chave_resultado):
    import numpy as np
    import redis
    import io

    resultados = []

    for i in range(particoes):
        A = np.random.rand(p, p)
        autovalores = np.linalg.eigvals(A)
        raio = np.max(np.abs(autovalores))
        resultados.append(raio)
    
    # 2. Serializa o array NumPy em bytes (para não perder precisão e trafegar rápido)
    buffer = io.BytesIO()
    np.save(buffer, np.array(resultados))
    dados_bytes = buffer.getvalue()
    
    # 3. Conecta no Redis a partir do Worker e faz um RPUSH na lista de resultados
    r = redis.from_url(redis_url)
    r.rpush(chave_resultado, dados_bytes)
    
    return "Enviado para a lista com sucesso"

# --- FLUXO DE DISPARO E RECOLETA NO MASTER ---
def executar_fluxo_master():
    NOME_DA_LISTA_RESULTADOS = 'lista_resultados_matriz'

    p = 200
    n_iter = 1000
    particoes_restantes = n_iter
    t_particoes = 200
    contador_jobs = 0

    print("🚀 Enviando pedidos para o cluster de Workers...")
    
    # Loop de fatiamento e envio dinâmico
    while particoes_restantes > 0: 
        contador_jobs += 1

        if particoes_restantes >= t_particoes: 
            job = fila.enqueue(
                processar_e_listar, 
                args=(p, t_particoes, REDIS_URL, NOME_DA_LISTA_RESULTADOS),
                job_timeout='3h'
            )
            particoes_restantes = particoes_restantes - t_particoes
            print(f"✅ Job {contador_jobs} ({job.id}) entrou na fila com {t_particoes} iterações. Restam: {particoes_restantes}")
            
        else:
            job = fila.enqueue(
                processar_e_listar, 
                args=(p, particoes_restantes, REDIS_URL, NOME_DA_LISTA_RESULTADOS),
                job_timeout='3h'
            )
            print(f"✅ Job {contador_jobs} ({job.id}) entrou na fila com a sobra de {particoes_restantes} iterações.")
            particoes_restantes = 0

    # Coleta de dados dinâmica baseada no número de jobs disparados
    print(f"\n⏳ Monitorando a lista para recolher {contador_jobs} resultados com LPOP...")
    resultados_coletados = 0
    
    while resultados_coletados < contador_jobs:
        dados_brutos = r_client.lpop(NOME_DA_LISTA_RESULTADOS)
        
        if dados_brutos:
            resultados_coletados += 1
            print(f"\n📥 [{resultados_coletados}/{contador_jobs}] Resultado retirado da esquerda via LPOP!")
            
            buffer = io.BytesIO(dados_brutos)
            array_final = np.load(buffer)
            print(f"Formato do Array recebido: {array_final.shape}")
        else:
            print(".", end="", flush=True)
            time.sleep(1)
            
    print("\n🏆 Todos os pedidos foram processados e recolhidos!")

if __name__ == "__main__":
    executar_fluxo_master()
